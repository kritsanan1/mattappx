
# Thai Recovery App - Environment Configuration
# Copy this file to .env and fill in your specific values

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================

# Application Name and Version
EXPO_PUBLIC_APP_NAME=Thai Recovery
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_APP_ENVIRONMENT=development

# App Store Configuration
EXPO_PUBLIC_APP_BUNDLE_ID=com.thairecovery.app
EXPO_PUBLIC_APP_SCHEME=thairecovery

# ==============================================
# DEVELOPMENT CONFIGURATION
# ==============================================

# Development Server Configuration
EXPO_PUBLIC_DEV_SERVER_URL=http://localhost:8081
EXPO_PUBLIC_API_BASE_URL=https://api.thairecovery.local

# Debug and Logging
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_LOG_LEVEL=debug
EXPO_PUBLIC_ENABLE_FLIPPER=true

# ==============================================
# API CONFIGURATION
# ==============================================

# Backend API Configuration
EXPO_PUBLIC_API_URL=https://api.thairecovery.com
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_API_TIMEOUT=30000

# API Authentication
EXPO_PUBLIC_API_KEY=your_api_key_here
API_SECRET_KEY=your_secret_key_here_keep_private

# External Service APIs
EXPO_PUBLIC_ANALYTICS_API_KEY=your_analytics_key
EXPO_PUBLIC_CRASH_REPORTING_KEY=your_crash_reporting_key

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================

# Authentication Configuration
EXPO_PUBLIC_AUTH_PROVIDER=supabase
EXPO_PUBLIC_AUTH_REDIRECT_URL=thairecovery://auth/callback

# Supabase Configuration (if using Supabase)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_keep_private

# Encryption Keys (Generate unique keys for production)
EXPO_PUBLIC_ENCRYPTION_KEY=your_32_character_encryption_key
DATA_ENCRYPTION_SALT=your_unique_salt_string

# ==============================================
# FEATURE FLAGS
# ==============================================

# Core Features
EXPO_PUBLIC_ENABLE_AI_INSIGHTS=true
EXPO_PUBLIC_ENABLE_MOOD_TRACKING=true
EXPO_PUBLIC_ENABLE_PROGRESS_CHARTS=true
EXPO_PUBLIC_ENABLE_GAMIFICATION=true

# Advanced Features
EXPO_PUBLIC_ENABLE_COMMUNITY=false
EXPO_PUBLIC_ENABLE_VIDEO_CALLS=false
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true

# Beta Features (for testing)
EXPO_PUBLIC_ENABLE_BETA_FEATURES=false
EXPO_PUBLIC_ENABLE_EXPERIMENTAL_UI=false

# ==============================================
# NOTIFICATIONS
# ==============================================

# Push Notifications
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_NOTIFICATION_ICON=notification_icon

# Firebase Cloud Messaging (if using FCM)
EXPO_PUBLIC_FCM_SENDER_ID=your_fcm_sender_id
FCM_SERVER_KEY=your_fcm_server_key_keep_private

# Apple Push Notification Service (if using APNS)
APNS_KEY_ID=your_apns_key_id
APNS_TEAM_ID=your_apple_team_id
APNS_PRIVATE_KEY=your_apns_private_key_keep_private

# ==============================================
# ANALYTICS & MONITORING
# ==============================================

# Analytics Configuration
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ANALYTICS_PROVIDER=mixpanel

# Google Analytics
EXPO_PUBLIC_GA_TRACKING_ID=GA-XXXXXXXXX

# Mixpanel
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Sentry (Error Reporting)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=thai-recovery-app

# ==============================================
# LOCALIZATION
# ==============================================

# Language Configuration
EXPO_PUBLIC_DEFAULT_LANGUAGE=th
EXPO_PUBLIC_SUPPORTED_LANGUAGES=th,en
EXPO_PUBLIC_ENABLE_RTL=false

# Translation Service (if using external service)
TRANSLATION_API_KEY=your_translation_api_key

# ==============================================
# STORAGE & DATABASE
# ==============================================

# Local Storage Configuration
EXPO_PUBLIC_STORAGE_ENCRYPTION=true
EXPO_PUBLIC_MAX_STORAGE_SIZE=100MB

# Database Configuration (if using external database)
DATABASE_URL=your_database_connection_string
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000

# ==============================================
# AI & MACHINE LEARNING
# ==============================================

# AI Services Configuration
EXPO_PUBLIC_ENABLE_AI_FEATURES=true
EXPO_PUBLIC_AI_MODEL_VERSION=v1.0

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_keep_private
EXPO_PUBLIC_OPENAI_MODEL=gpt-3.5-turbo

# Custom AI Service
AI_SERVICE_URL=https://ai.thairecovery.com
AI_SERVICE_KEY=your_ai_service_key_keep_private

# ==============================================
# SOCIAL & COMMUNITY
# ==============================================

# Social Features
EXPO_PUBLIC_ENABLE_SOCIAL_SHARING=true
EXPO_PUBLIC_ENABLE_PEER_SUPPORT=false

# Social Media Integration
FACEBOOK_APP_ID=your_facebook_app_id
GOOGLE_CLIENT_ID=your_google_client_id
TWITTER_API_KEY=your_twitter_api_key

# ==============================================
# COMPLIANCE & PRIVACY
# ==============================================

# PDPA/GDPR Compliance
EXPO_PUBLIC_ENABLE_PRIVACY_CONTROLS=true
EXPO_PUBLIC_DATA_RETENTION_DAYS=365
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://thairecovery.com/privacy

# Content Moderation
EXPO_PUBLIC_ENABLE_CONTENT_MODERATION=true
CONTENT_MODERATION_API_KEY=your_moderation_api_key

# ==============================================
# DEPLOYMENT CONFIGURATION
# ==============================================

# Environment-specific URLs
EXPO_PUBLIC_WEB_URL=https://app.thairecovery.com
EXPO_PUBLIC_SUPPORT_URL=https://support.thairecovery.com
EXPO_PUBLIC_TERMS_URL=https://thairecovery.com/terms

# CDN Configuration
EXPO_PUBLIC_CDN_URL=https://cdn.thairecovery.com
EXPO_PUBLIC_ASSETS_URL=https://assets.thairecovery.com

# ==============================================
# PERFORMANCE & OPTIMIZATION
# ==============================================

# Performance Configuration
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
EXPO_PUBLIC_BUNDLE_SIZE_LIMIT=50MB
EXPO_PUBLIC_IMAGE_CACHE_SIZE=100MB

# Network Configuration
EXPO_PUBLIC_REQUEST_TIMEOUT=30000
EXPO_PUBLIC_RETRY_ATTEMPTS=3
EXPO_PUBLIC_OFFLINE_TIMEOUT=5000

# ==============================================
# SECURITY HEADERS & POLICIES
# ==============================================

# Content Security Policy
EXPO_PUBLIC_CSP_ENABLED=true
EXPO_PUBLIC_ALLOWED_DOMAINS=thairecovery.com,*.thairecovery.com

# Security Configuration
EXPO_PUBLIC_ENABLE_SSL_PINNING=true
EXPO_PUBLIC_ENABLE_ROOT_DETECTION=true
EXPO_PUBLIC_ENABLE_DEBUG_PROTECTION=true

# ==============================================
# TESTING CONFIGURATION
# ==============================================

# Test Environment
EXPO_PUBLIC_ENABLE_TEST_MODE=false
EXPO_PUBLIC_TEST_API_URL=https://test-api.thairecovery.com
TEST_USER_EMAIL=test@thairecovery.com
TEST_USER_PASSWORD=test_password_keep_private

# ==============================================
# BACKUP & RECOVERY
# ==============================================

# Backup Configuration
EXPO_PUBLIC_ENABLE_AUTO_BACKUP=true
EXPO_PUBLIC_BACKUP_FREQUENCY=daily
BACKUP_STORAGE_URL=your_backup_storage_url
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_keep_private

# ==============================================
# NOTES FOR DEVELOPERS
# ==============================================

# 1. Variables prefixed with EXPO_PUBLIC_ are available in the client
# 2. Variables without EXPO_PUBLIC_ are server-side only
# 3. Never commit sensitive keys to version control
# 4. Use different values for development, staging, and production
# 5. Regularly rotate API keys and secrets
# 6. Validate all environment variables on app startup
# 7. Use strong, unique encryption keys for each environment
# 8. Keep this file updated with new configuration options

# ==============================================
# ENVIRONMENT VALIDATION
# ==============================================

# Required variables (app will fail to start without these)
# - EXPO_PUBLIC_APP_NAME
# - EXPO_PUBLIC_APP_VERSION
# - EXPO_PUBLIC_API_URL (if using external API)
# - EXPO_PUBLIC_ENCRYPTION_KEY (for data security)

# Optional variables (app will use defaults if not provided)
# - Debug and logging configuration
# - Analytics and monitoring
# - Feature flags
# - Social media integration
